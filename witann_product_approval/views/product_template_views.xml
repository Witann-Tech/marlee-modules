<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_witann_product_approval" model="ir.ui.view">
        <field name="name">product.template.form.witann.product.approval</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_approve_pending_changes"
                        type="object"
                        string="Aprobar"
                        class="btn-primary"
                        groups="product.group_product_manager"
                        invisible="approval_state != 'pending'"/>
                <button name="action_reject_pending_changes"
                        type="object"
                        string="Rechazar"
                        groups="product.group_product_manager"
                        invisible="approval_state != 'pending'"/>
                <field name="approval_state"
                       widget="statusbar"
                       statusbar_visible="pending,approved,rejected"/>
            </xpath>

            <xpath expr="//sheet//group[1]" position="after">
                <group string="Autorización de producto">
                    <group>
                        <field name="approval_requested_by_id" readonly="1"/>
                        <field name="approval_requested_on" readonly="1"/>
                    </group>
                    <group>
                        <field name="approval_approved_by_id" readonly="1"/>
                        <field name="approval_approved_on" readonly="1"/>
                    </group>
                    <group>
                        <field name="last_change_request_id" readonly="1"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
