<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_witann_product_approval_v2" model="ir.ui.view">
        <field name="name">product.template.form.witann.product.approval</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Autorización de producto">
                    <group>
                        <field name="approval_state" readonly="1"/>
                        <field name="approval_requested_by_id" readonly="1"/>
                        <field name="approval_requested_on" readonly="1"/>
                    </group>
                    <group>
                        <field name="approval_approved_by_id" readonly="1"/>
                        <field name="approval_approved_on" readonly="1"/>
                    </group>
                    <group>
                        <field name="last_change_request_id" readonly="1"/>
                    </group>
                    <group groups="product.group_product_manager">
                        <button name="action_approve_pending_changes"
                                type="object"
                                string="Aprobar pendientes"
                                class="btn-primary"
                                invisible="approval_state != 'pending'"/>
                        <button name="action_reject_pending_changes"
                                type="object"
                                string="Rechazar pendientes"
                                invisible="approval_state != 'pending'"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
