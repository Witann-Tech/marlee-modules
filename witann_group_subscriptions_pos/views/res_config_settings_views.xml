<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="res_config_settings_view_form_wgs_authorization_pin" model="ir.ui.view">
      <field name="name">res.config.settings.form.wgs.authorization.pin</field>
      <field name="model">res.config.settings</field>
      <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
      <field name="arch" type="xml">
        <xpath expr="//form" position="inside">
          <app string="Suscripciones POS" name="wgs_subscriptions_pos_settings" data-string="Suscripciones POS">
            <block title="Autorizaciones">
              <setting id="wgs_authorization_pin_rotation_days" string="Rotación de PIN de autorización" help="Regenera automáticamente el PIN de autorización WGS de empleados que ya tienen PIN registrado. Usa 0 para desactivar la rotación.">
                <field name="wgs_authorization_pin_rotation_days"/>
                <span class="ms-2">días</span>
              </setting>
            </block>
          </app>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
