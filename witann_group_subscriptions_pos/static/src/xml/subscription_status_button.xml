<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="witann_group_subscriptions_pos.ControlButtons"
       t-inherit="point_of_sale.ControlButtons"
       t-inherit-mode="extension"
        owl="1">
        <xpath expr="//SelectPartnerButton" position="after">
            <div class="wgs-control-buttons-row">
                <button class="btn btn-light rounded-0 fw-bolder wgs-control-button" t-on-click="onClickSubscriptionStatus" type="button">
                    <i class="fa fa-id-card me-1"/>
                    Control de acceso
                </button>
            </div>
        </xpath>
    </t>
</templates>
