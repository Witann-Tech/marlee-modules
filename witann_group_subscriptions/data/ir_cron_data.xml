<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">
    <record id="ir_cron_wgs_sync_subscription_access_control" model="ir.cron">
      <field name="name">WGS: resincronizar acceso de suscripciones</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="state">code</field>
      <field name="code">model._cron_wgs_sync_subscription_access_control()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">hours</field>
      <field name="active">True</field>
    </record>

    <record id="ir_cron_wgs_close_overdue_subscriptions" model="ir.cron">
      <field name="name">WGS: cerrar suscripciones vencidas por plan</field>
      <field name="model_id" ref="sale.model_sale_order"/>
      <field name="state">code</field>
      <field name="code">model._cron_wgs_close_overdue_subscriptions()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="active">True</field>
    </record>
  </data>
</odoo>
