<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_witann_group_subscriptions" model="ir.ui.view">
        <field name="name">product.template.form.witann.group.subscriptions</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Suscripción grupal" name="group_subscription_settings" invisible="not recurring_invoice">
                    <group>
                        <field name="max_participants_total"/>
                        <field name="subscription_minimum_term_periods"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
