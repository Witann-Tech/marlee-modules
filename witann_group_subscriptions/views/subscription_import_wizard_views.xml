<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wgs_subscription_import_wizard_form" model="ir.ui.view">
        <field name="name">wgs.subscription.import.wizard.form</field>
        <field name="model">wgs.subscription.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar suscripciones vigentes" create="false" edit="true">
                <sheet>
                    <group>
                        <group>
                            <field name="file_name" invisible="1"/>
                            <field name="file_data" filename="file_name"/>
                            <field name="batch_name"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="dry_run"/>
                            <field name="update_existing"/>
                            <field name="skip_non_current"/>
                            <field name="active_state_mode"/>
                            <field name="customer_id_partner_field_names"/>
                        </group>
                    </group>
                    <separator string="Formato esperado"/>
                    <div class="alert alert-info" role="alert">
                        Columnas mínimas: <b>plan</b>, <b>inicio</b> y <b>fin</b>, más alguna llave para identificar al usuario:
                        <b>partner_id</b>, <b>ID Cliente</b>, <b>xml_id/external_id</b>, <b>ref</b>, <b>email</b>, <b>mobile</b>,
                        <b>phone</b>, <b>vat</b> o <b>name</b>.
                    </div>
                    <div class="text-muted">
                        Columnas opcionales: <b>subscription_plan</b>, <b>price</b>, <b>quantity</b> y <b>participants/participantes</b>.
                        El campo <b>plan</b> se mapea al producto recurrente.
                    </div>
                    <group invisible="not result_summary">
                        <field name="result_summary" readonly="1"/>
                    </group>
                    <group invisible="not result_log">
                        <field name="result_log" readonly="1" nolabel="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_process_file" string="Procesar" type="object" class="btn-primary"/>
                    <button string="Cerrar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wgs_subscription_import_wizard" model="ir.actions.act_window">
        <field name="name">Importar suscripciones vigentes</field>
        <field name="res_model">wgs.subscription.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="sale.model_sale_order"/>
        <field name="binding_view_types">list,form</field>
    </record>
</odoo>
