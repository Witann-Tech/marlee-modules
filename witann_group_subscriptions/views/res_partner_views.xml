<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_wgs_subscription_package" model="ir.ui.view">
        <field name="name">res.partner.tree.wgs.subscription.package</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="wgs_subscription_package_names" optional="show"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_form_wgs_subscription_package" model="ir.ui.view">
        <field name="name">res.partner.form.wgs.subscription.package</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="access_control_api.view_partner_form_access_control"/>
        <field name="arch" type="xml">
            <xpath expr="(//field[@name='access_origin'])[1]" position="after">
                <field name="wgs_subscription_package_names" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_partner_search_wgs_subscription_package" model="ir.ui.view">
        <field name="name">res.partner.search.wgs.subscription.package</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_res_partner_filter"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="wgs_subscription_package_names"/>
            </xpath>
        </field>
    </record>
</odoo>
