<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="access_control_api.FaceCameraField">
        <div class="o_face_camera_field">
            <div class="mb-2">
                <img t-if="imageSrc" t-att-src="imageSrc" class="img img-fluid rounded border" alt="Foto de rostro"/>
                <div t-else="" class="text-muted">Sin foto</div>
            </div>

            <t t-if="!props.readonly">
                <div class="d-flex gap-2 flex-wrap">
                    <label class="btn btn-secondary mb-0">
                        Subir archivo
                        <input type="file" class="d-none" accept="image/*" t-on-change="onFileChange"/>
                    </label>
                    <button type="button" class="btn btn-primary" t-on-click="takePhoto">
                        Tomar foto
                    </button>
                    <button t-if="hasValue" type="button" class="btn btn-outline-secondary" t-on-click="clearImage">
                        Limpiar
                    </button>
                </div>
            </t>
        </div>
    </t>
</templates>
