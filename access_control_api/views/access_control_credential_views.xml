<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_credential_tree" model="ir.ui.view">
      <field name="name">access_control.credential.tree</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <tree string="Credentials">
          <field name="active"/>
          <field name="fingerprint_id"/>
          <field name="user_id"/>
          <field name="partner_id"/>
          <field name="note"/>
        </tree>
      </field>
    </record>

    <record id="view_access_control_credential_form" model="ir.ui.view">
      <field name="name">access_control.credential.form</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <form string="Credential">
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="fingerprint_id"/>
            </group>
            <group string="Links">
              <field name="user_id"/>
              <field name="partner_id"/>
              <field name="note"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_credential_search" model="ir.ui.view">
      <field name="name">access_control.credential.search</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <search string="Credentials">
          <field name="fingerprint_id"/>
          <field name="user_id"/>
          <field name="partner_id"/>
          <filter string="Active" name="active" domain="[('active','=',True)]"/>
          <filter string="Inactive" name="inactive" domain="[('active','=',False)]"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
