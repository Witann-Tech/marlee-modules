<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_credential_list" model="ir.ui.view">
      <field name="name">access_control.credential.list</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <list string="Credentials">
          <field name="active"/>
          <field name="partner_id"/>
          <field name="person_id"/>
          <field name="site_id"/>
          <field name="credential_type"/>
          <field name="enroll_status"/>
          <field name="pin_value" password="True" invisible="credential_type != 'pin'"/>
          <field name="finger_index" invisible="credential_type != 'fingerprint'"/>
          <field name="template_format" invisible="credential_type != 'fingerprint'"/>
          <field name="note"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_credential_form" model="ir.ui.view">
      <field name="name">access_control.credential.form</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <form string="Credential">
          <header>
            <button name="action_request_enroll" type="object" string="Enroll (ZK9500)" class="btn-primary" invisible="credential_type != 'fingerprint' or enroll_status in ('requested','enrolling','active')"/>
            <button name="action_cancel_enroll" type="object" string="Cancel Enroll" class="btn-secondary" invisible="credential_type != 'fingerprint' or enroll_status not in ('requested','enrolling')"/>
          </header>
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="partner_id" readonly="1"/>
              <field name="person_id" required="1"/>
              <field name="site_id" readonly="1"/>
              <field name="credential_type"/>
              <field name="pin_value" password="True" invisible="credential_type != 'pin'"/>
              <field name="finger_index" invisible="credential_type != 'fingerprint'"/>
              <field name="template_format" invisible="credential_type != 'fingerprint'"/>
              <field name="template_b64" invisible="credential_type != 'fingerprint'"/>
              <field name="note"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_credential_search" model="ir.ui.view">
      <field name="name">access_control.credential.search</field>
      <field name="model">access_control.credential</field>
      <field name="arch" type="xml">
        <search string="Credentials">
          <field name="partner_id"/>
          <field name="person_id"/>
          <field name="site_id"/>
          <field name="credential_type"/>
          <field name="active"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
