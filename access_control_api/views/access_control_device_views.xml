<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_device_tree" model="ir.ui.view">
      <field name="name">access_control.device.tree</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <list string="Devices">
          <field name="active"/>
          <field name="name"/>
          <field name="device_code"/>
          <field name="site_id"/>
          <field name="user_capacity"/>
          <field name="last_heartbeat_at"/>
          <field name="last_sync_at"/>
          <field name="last_error"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_device_form" model="ir.ui.view">
      <field name="name">access_control.device.form</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <form string="Device">
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="name"/>
              <field name="device_code"/>
              <field name="site_id" options="{'no_create_edit': False}"/>
              <field name="user_capacity"/>
            </group>
            <group string="Telemetry">
              <field name="last_heartbeat_at" readonly="1"/>
              <field name="last_sync_at" readonly="1"/>
              <field name="last_error" readonly="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_device_search" model="ir.ui.view">
      <field name="name">access_control.device.search</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <search string="Devices">
          <field name="name"/>
          <field name="device_code"/>
          <field name="site_id"/>
          <field name="active"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
