<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_device_tree" model="ir.ui.view">
      <field name="name">access_control.device.lista</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <list string="Dispositivos">
          <field name="active"/>
          <field name="name"/>
          <field name="device_serial"/>
          <field name="site_id"/>
          <field name="user_capacity"/>
          <field name="last_heartbeat_at"/>
          <field name="last_sync_at"/>
          <field name="last_error"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_device_form" model="ir.ui.view">
      <field name="name">access_control.device.formulario</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <form string="Dispositivo">
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="name"/>
              <field name="device_serial"/>
              <field name="site_id" options="{'no_create_edit': False}"/>
              <field name="user_capacity"/>
            </group>
            <group string="Telemetría">
              <field name="last_heartbeat_at" readonly="1"/>
              <field name="last_sync_at" readonly="1"/>
              <field name="last_error" readonly="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_device_search" model="ir.ui.view">
      <field name="name">access_control.device.buscar</field>
      <field name="model">access_control.device</field>
      <field name="arch" type="xml">
        <search string="Dispositivos">
          <field name="name"/>
          <field name="device_serial"/>
          <field name="site_id"/>
          <field name="active"/>
          <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
          <filter name="archived" string="Archivados" domain="[('active', '=', False)]"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
