<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_partner_tree_access_control" model="ir.ui.view">
      <field name="name">res.partner.tree.access.control</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_tree"/>
      <field name="arch" type="xml">
        <xpath expr="//list" position="inside">
          <field name="access_global_user_id" optional="hide" groups="access_control_api.group_access_control_contact_access"/>
          <field name="access_origin" optional="hide" groups="access_control_api.group_access_control_contact_access"/>
          <field name="access_timezone_id" optional="hide" groups="access_control_api.group_access_control_contact_access"/>
          <field name="access_authorize_timezone_id" optional="hide" groups="access_control_api.group_access_control_contact_access"/>
          <field name="access_last_access_at" optional="hide" groups="access_control_api.group_access_control_contact_access"/>
        </xpath>
      </field>
    </record>

    <record id="view_partner_form_access_control" model="ir.ui.view">
      <field name="name">res.partner.form.access.control</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form"/>
      <field name="arch" type="xml">
        <xpath expr="//field[@name='image_1920'][1]" position="attributes">
          <attribute name="widget">image</attribute>
        </xpath>
        <xpath expr="//field[@name='image_1920'][1]/.." position="inside">
          <div class="mt-2" groups="access_control_api.group_access_control_contact_access">
            <field name="camera_capture_helper" widget="face_camera_button" nolabel="1" readonly="0" groups="access_control_api.group_access_control_contact_access"/>
          </div>
        </xpath>
        <xpath expr="//notebook" position="inside">
          <page string="Control de Acceso" groups="access_control_api.group_access_control_contact_access">
            <group string="Resumen">
              <field name="access_global_user_id" readonly="1"/>
              <field name="access_origin" readonly="1"/>
              <field name="access_timezone_id" readonly="1"/>
              <field name="access_authorize_timezone_id" readonly="1"/>
            </group>
            <field name="access_person_ids" context="{'default_partner_id': id}" nolabel="1" groups="access_control_api.group_access_control_contact_access">
              <list editable="bottom" string="Personas de acceso">
                <field name="active"/>
                <field name="access_origin" readonly="1"/>
                <field name="global_user_id"/>
                <field name="access_timezone_id"/>
                <field name="authorize_timezone_id" readonly="1"/>
                <field name="site_ids" widget="many2many_tags"/>
                <field name="face_image" string="Biopic SF" widget="image" readonly="1" options="{'size': [64, 64]}"/>
                <field name="last_sf_sync_at" readonly="1"/>
                <field name="last_access_at" readonly="1"/>
                <field name="last_access_result" readonly="1"/>
              </list>
              <form string="Persona de acceso">
                <sheet>
                  <group>
                    <field name="active" widget="boolean_toggle"/>
                    <field name="access_origin" readonly="1"/>
                    <field name="global_user_id"/>
                    <field name="access_timezone_id"/>
                    <field name="authorize_timezone_id" readonly="1"/>
                    <field name="site_ids" widget="many2many_tags"/>
                    <field name="face_image" string="Biopic SF" widget="image" readonly="1" options="{'size': [160, 160]}"/>
                    <field name="last_sf_sync_at" readonly="1"/>
                    <field name="last_access_at" readonly="1"/>
                    <field name="last_access_result" readonly="1"/>
                    <field name="last_access_site_id" readonly="1"/>
                    <field name="last_access_device_id" readonly="1"/>
                    <field name="face_pic_b64" invisible="1"/>
                  </group>
                </sheet>
              </form>
            </field>
          </page>
        </xpath>
      </field>
    </record>
  </data>
</odoo>
