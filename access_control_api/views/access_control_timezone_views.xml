<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_timezone_tree" model="ir.ui.view">
      <field name="name">access_control.timezone.lista</field>
      <field name="model">access_control.timezone</field>
      <field name="arch" type="xml">
        <list string="Horarios de acceso">
          <field name="active"/>
          <field name="timezone_id"/>
          <field name="name"/>
          <field name="interval_summary"/>
          <field name="sync_state"/>
          <field name="last_sync_at"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_timezone_form" model="ir.ui.view">
      <field name="name">access_control.timezone.formulario</field>
      <field name="model">access_control.timezone</field>
      <field name="arch" type="xml">
        <form string="Horario de acceso">
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle" readonly="is_general"/>
              <field name="timezone_id" readonly="1"/>
              <field name="name" readonly="is_general"/>
              <field name="description" readonly="is_general"/>
              <field name="sync_state" readonly="1"/>
              <field name="last_sync_at" readonly="1"/>
              <field name="is_general" invisible="1"/>
            </group>
            <group string="Ventanas">
              <field name="interval_ids" readonly="is_general">
                <list editable="bottom">
                  <field name="day"/>
                  <field name="sequence"/>
                  <field name="start_time"/>
                  <field name="end_time"/>
                </list>
              </field>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_timezone_search" model="ir.ui.view">
      <field name="name">access_control.timezone.buscar</field>
      <field name="model">access_control.timezone</field>
      <field name="arch" type="xml">
        <search string="Horarios de acceso">
          <field name="name"/>
          <field name="timezone_id"/>
          <filter name="active" string="Activos" domain="[('active', '=', True)]"/>
          <filter name="archived" string="Archivados" domain="[('active', '=', False)]"/>
          <filter name="pending" string="Pendientes de sync" domain="[('sync_state', '=', 'pending')]"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
