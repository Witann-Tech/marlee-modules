<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_person_tree" model="ir.ui.view">
      <field name="name">access_control.person.list</field>
      <field name="model">access_control.person</field>
      <field name="arch" type="xml">
        <list string="People">
          <field name="active"/>
          <field name="name"/>
          <field name="global_user_id" readonly="active"/>
          <field name="site_ids" widget="many2many_tags"/>
          <field name="has_face_pic"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_person_form" model="ir.ui.view">
      <field name="name">access_control.person.form</field>
      <field name="model">access_control.person</field>
      <field name="arch" type="xml">
        <form string="Person">
          <header>
            <button name="action_assign_global_user_id" type="object" string="Assign Global ID" class="btn-secondary" invisible="global_user_id"/>
            <button name="action_activate" type="object" string="Activate" class="btn-primary" invisible="active"/>
            <button name="action_deactivate" type="object" string="Deactivate" class="btn-secondary" invisible="not active"/>
          </header>
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="partner_id" required="1"/>
              <field name="name" readonly="1"/>
              <field name="global_user_id" readonly="active"/>
              <field name="site_ids" widget="many2many_tags" options="{'no_create_edit': False}"/>
              <field name="has_face_pic" readonly="1"/>
            </group>
            <group string="Face Photo">
              <field name="face_image" widget="image" class="oe_avatar"/>
              <field name="face_pic_b64" invisible="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_access_control_person_search" model="ir.ui.view">
      <field name="name">access_control.person.search</field>
      <field name="model">access_control.person</field>
      <field name="arch" type="xml">
        <search string="People">
          <field name="name"/>
          <field name="global_user_id"/>
          <field name="site_ids"/>
          <filter string="With Face Pic" name="with_face_pic" domain="[('face_pic_b64','!=',False)]"/>
          <filter string="Active" name="active" domain="[('active','=',True)]"/>
          <filter string="Inactive" name="inactive" domain="[('active','=',False)]"/>
        </search>
      </field>
    </record>
  </data>
</odoo>
