<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_access_control_site_tree" model="ir.ui.view">
      <field name="name">access_control.site.tree</field>
      <field name="model">access_control.site</field>
      <field name="arch" type="xml">
        <list string="Sites">
          <field name="name"/>
          <field name="code"/>
          <field name="force_sync"/>
          <field name="slots_used" readonly="1"/>
          <field name="slots_total" readonly="1"/>
          <field name="slots_percent" widget="progressbar" readonly="1"/>
          <field name="active"/>
        </list>
      </field>
    </record>

    <record id="view_access_control_site_form" model="ir.ui.view">
      <field name="name">access_control.site.form</field>
      <field name="model">access_control.site</field>
      <field name="arch" type="xml">
        <form string="Site">
          <sheet>
            <group>
              <field name="active" widget="boolean_toggle"/>
              <field name="name"/>
              <field name="code"/>
              <field name="force_sync"/>
              <field name="slots_used" readonly="1"/>
              <field name="slots_total" readonly="1"/>
              <field name="slots_percent" widget="progressbar" readonly="1"/>
            </group>
            <notebook>
              <page string="Devices">
                <field name="device_ids" nolabel="1">
                  <list editable="bottom">
                    <field name="active"/>
                    <field name="name"/>
                    <field name="device_serial"/>
                    <field name="user_capacity"/>
                    <field name="last_heartbeat_at" readonly="1"/>
                    <field name="last_sync_at" readonly="1"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>
  </data>
</odoo>
